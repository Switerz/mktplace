# --- Banco de dados local (app prÃ³prio) ---
DATABASE_URL=postgresql://user:password@localhost:5432/mktplace_control
DATABASE_TEST_URL=postgresql://user:password@localhost:5432/mktplace_control_test

# --- Data Mart (leitura â€” fonte de dados existente) ---
DATAMART_HOST=
